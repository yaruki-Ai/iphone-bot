# =============================================================================
# .env.example — Modèle de configuration. Copier en .env et compléter.
# =============================================================================

# --- Application ---
APP_HOST=127.0.0.1
APP_PORT=8000
# false = données réelles uniquement ; true = données de démonstration.
SIMULATION_MODE=false
SCAN_INTERVAL_MINUTES=12
SEUIL_ALERTE_SCORE=70
MARGE_CIBLE_POURCENT=30

# --- eBay : scraping classique de eBay.fr (aucune clé requise) ---

# --- Discord (Salon → Intégrations → Webhooks) ---
DISCORD_WEBHOOK_ALERTES=
DISCORD_WEBHOOK_RAPPORT=

# --- Leboncoin (compte dédié, scraping anonyme, cooldown auto si blocage) ---
LBC_EMAIL=
LBC_PASSWORD=

# --- Vinted : scraping classique anonyme, aucun token requis ---
